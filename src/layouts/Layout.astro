---
import '../styles/solid-state.scss';
import '../styles/fontawesome.css';
import '../styles/global.css';

interface Props {
  title: string;
  /** Add .alt to <header> (transparent over hero banner). Default: false. */
  headerAlt?: boolean;
}

const { title, headerAlt = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- Google Fonts: preconnect first, then non-blocking stylesheet link -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@200;700&family=Source+Sans+Pro:ital,wght@0,300;0,600;1,300;1,600&display=swap"
    />
  </head>

  <body class="is-preload">
    <div id="page-wrapper">
      <slot />
    </div>

    <!-- Compiled + tree-shaken by Astro/Vite; replaces all jQuery scripts -->
    <script>
      import '../scripts/site';
    </script>
  </body>
</html>

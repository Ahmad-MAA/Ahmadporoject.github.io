---
/**
 * Full-width alternating image + text row (the "spotlight" section style).
 *
 * By default, CSS nth-child(2n-1) flips image/text order on odd children of
 * #wrapper. Pass `imageRight` explicitly to lock a project's image side
 * independently of DOM position (required when reordering projects).
 *
 * `alt` controls clip-triangle direction + colour variant (style2 vs style1).
 * `rectangular` removes the default oval framing; use for screenshot images.
 */
import { Image } from 'astro:assets';

interface Props {
  title: string;
  image: ImageMetadata;
  imageAlt: string;
  href: string;
  /** Optional second CTA — renders a "Try it live" link when provided. */
  liveHref?: string;
  /** Explicitly place image right (true) or left (false). Omit to use CSS nth-child auto-alternation. */
  imageRight?: boolean;
  /** Remove oval framing; use flat 5px border-radius instead. */
  rectangular?: boolean;
  /** Flips clip direction and uses darker accent (style2). Default: false. */
  alt?: boolean;
}

const { title, image, imageAlt, href, liveHref, imageRight, rectangular, alt = false } = Astro.props;
const wrapperStyle = alt ? 'style2' : 'style1';

// Only applied when imageRight is explicitly provided; overrides nth-child
const innerStyle = imageRight === true
  ? 'flex-direction: row-reverse; text-align: right;'
  : imageRight === false
  ? 'flex-direction: row; text-align: left;'
  : undefined;

// Margin values match $size(section-spacing.large)=3em, $size(element-margin)=2em (_vars.scss)
const imageStyle = [
  imageRight === true  ? 'margin: 0 0 2em 3em;' :
  imageRight === false ? 'margin: 0 3em 2em 0;' : '',
  rectangular ? 'border-radius: 5px; overflow: visible;' : '',
].filter(Boolean).join(' ') || undefined;
---
<section class:list={['wrapper', 'spotlight', wrapperStyle, { alt }]}>
  <div class="inner" style={innerStyle}>
    <a href="#" class="image" style={imageStyle}>
      <Image src={image} alt={imageAlt} width={700} format="webp" style={rectangular ? 'border-radius: 5px;' : undefined} />
    </a>
    <div class="content">
      <h2 class="major">{title}</h2>
      <slot />
      <a href={href} class="special" target="_blank" rel="noopener">Learn more</a>
      {liveHref && <a href={liveHref} class="special" target="_blank" rel="noopener">Try it live</a>}
    </div>
  </div>
</section>

---
/**
 * Card-style project tile used inside the `.features` grid.
 * Image bleeds full card width (top), followed by title, slot content, and CTA(s).
 */
import { Image } from 'astro:assets';

interface Props {
  title: string;
  image: ImageMetadata;
  imageAlt: string;
  href: string;
  /** Optional second CTA — renders a "Try it live" link when provided. */
  liveHref?: string;
}

const { title, image, imageAlt, href, liveHref } = Astro.props;
---
<article>
  <a href="#" class="image">
    <Image src={image} alt={imageAlt} width={400} format="webp" />
  </a>
  <h3 class="major">{title}</h3>
  <slot />
  <a href={href} class="special" target="_blank" rel="noopener">Learn more</a>
  {liveHref && <a href={liveHref} class="special" target="_blank" rel="noopener">Try it live</a>}
</article>
